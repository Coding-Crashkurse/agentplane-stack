{
  "realm": "agentplane",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "agentplane platform admin"
      },
      {
        "name": "user",
        "description": "agentplane platform user"
      },
      {
        "name": "builder",
        "description": "agentplane flow builder"
      }
    ]
  },
  "groups": [
    {
      "name": "platform-admins",
      "path": "/platform-admins",
      "realmRoles": [
        "admin"
      ],
      "clientRoles": {
        "realm-management": [
          "view-users",
          "query-users",
          "manage-users",
          "view-realm"
        ]
      }
    },
    {
      "name": "acme",
      "path": "/acme"
    }
  ],
  "users": [
    {
      "username": "demo-admin",
      "enabled": true,
      "email": "demo-admin@example.com",
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "user",
        "builder"
      ],
      "groups": [
        "/platform-admins",
        "/acme"
      ]
    },
    {
      "username": "demo-user",
      "enabled": true,
      "email": "demo-user@example.com",
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "user",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "demo-builder",
      "enabled": true,
      "email": "demo-builder@example.com",
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Builder",
      "credentials": [
        {
          "type": "password",
          "value": "builder",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user",
        "builder"
      ]
    },
    {
      "username": "service-account-agentplane-cli",
      "enabled": true,
      "serviceAccountClientId": "agentplane-cli",
      "realmRoles": [
        "admin"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "agentplane-cli",
      "name": "agentplane CLI / smoke tests",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "agentplane-cli-secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "defaultClientScopes": [
        "basic",
        "roles",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "agentplane",
            "access.token.claim": "true"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "agentplane-ui",
      "name": "agentplane portal (SPA)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://app.localhost/*"
      ],
      "webOrigins": [
        "http://app.localhost"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://app.localhost/*"
      },
      "defaultClientScopes": [
        "basic",
        "roles",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "agentplane",
            "access.token.claim": "true"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "agentplane-builder",
      "name": "agentplane builder (SPA)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://builder.localhost/*"
      ],
      "webOrigins": [
        "http://builder.localhost"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://builder.localhost/*"
      },
      "defaultClientScopes": [
        "basic",
        "roles",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "agentplane",
            "access.token.claim": "true"
          }
        },
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "agentplane",
      "name": "agentplane audience",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false
    },
    {
      "clientId": "langfuse",
      "name": "Langfuse SSO",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "langfuse-client-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://langfuse.localhost/api/auth/callback/keycloak"
      ],
      "webOrigins": [
        "http://langfuse.localhost"
      ],
      "defaultClientScopes": [
        "basic",
        "roles",
        "profile",
        "email",
        "web-origins"
      ],
      "authenticationFlowBindingOverrides": {
        "browser": "f339fca2-52b2-4f38-a075-e29417079dad"
      }
    }
  ],
  "defaultRoles": [
    "user"
  ],
  "authenticationFlows": [
    {
      "id": "f339fca2-52b2-4f38-a075-e29417079dad",
      "alias": "langfuse browser",
      "description": "Browser flow for the langfuse client: platform admins only",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticatorFlow": true,
          "flowAlias": "langfuse authenticate",
          "requirement": "REQUIRED",
          "priority": 10,
          "userSetupAllowed": false
        },
        {
          "authenticatorFlow": true,
          "flowAlias": "langfuse admin gate",
          "requirement": "CONDITIONAL",
          "priority": 20,
          "userSetupAllowed": false
        }
      ]
    },
    {
      "id": "a11a5e0e-1f6e-4c3a-9a67-2b9f1c6b1004",
      "alias": "langfuse authenticate",
      "description": "cookie / password alternatives",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 10,
          "userSetupAllowed": false
        },
        {
          "authenticator": "identity-provider-redirector",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "userSetupAllowed": false
        },
        {
          "authenticatorFlow": true,
          "flowAlias": "langfuse forms",
          "requirement": "ALTERNATIVE",
          "priority": 30,
          "userSetupAllowed": false
        }
      ]
    },
    {
      "id": "a11a5e0e-1f6e-4c3a-9a67-2b9f1c6b1000",
      "alias": "langfuse forms",
      "description": "username/password",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-password-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10,
          "userSetupAllowed": false
        }
      ]
    },
    {
      "id": "a11a5e0e-1f6e-4c3a-9a67-2b9f1c6b1001",
      "alias": "langfuse admin gate",
      "description": "deny access unless the user has the admin role",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "conditional-user-role",
          "authenticatorConfig": "langfuse-admin-role-condition",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10,
          "userSetupAllowed": false
        },
        {
          "authenticator": "deny-access-authenticator",
          "authenticatorConfig": "langfuse-deny-message",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 20,
          "userSetupAllowed": false
        }
      ]
    }
  ],
  "authenticatorConfig": [
    {
      "id": "a11a5e0e-1f6e-4c3a-9a67-2b9f1c6b1002",
      "alias": "langfuse-admin-role-condition",
      "config": {
        "condUserRole": "admin",
        "negate": "true"
      }
    },
    {
      "id": "a11a5e0e-1f6e-4c3a-9a67-2b9f1c6b1003",
      "alias": "langfuse-deny-message",
      "config": {
        "denyErrorMessage": "Traces are restricted to administrators."
      }
    }
  ]
}
